# ───────────────────────────────────────────
# Telegram
# ───────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_WEBHOOK_SECRET=your-webhook-secret

# ───────────────────────────────────────────
# ClickUp
# ───────────────────────────────────────────
CLICKUP_API_TOKEN=your-clickup-api-token
CLICKUP_TEAM_ID=your-clickup-team-id
CLICKUP_WEBHOOK_SECRET=your-clickup-webhook-secret

# ───────────────────────────────────────────
# Anthropic (Claude Sonnet — fallback)
# ───────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ───────────────────────────────────────────
# Google AI Studio (Gemini Flash — principal)
# ───────────────────────────────────────────
GOOGLE_AI_API_KEY=AIza...

# ───────────────────────────────────────────
# App
# ───────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
APP_SECRET_KEY=your-app-secret-key

# ───────────────────────────────────────────
# Database
# ───────────────────────────────────────────
DATABASE_URL=sqlite:///./data/secretary.db

# ───────────────────────────────────────────
# Model routing
# ───────────────────────────────────────────
DEFAULT_MODEL=gemini-flash
COMPLEX_MODEL=claude-sonnet

# ───────────────────────────────────────────
# LangSmith (optional — tracing)
# ───────────────────────────────────────────
LANGSMITH_API_KEY=ls__...
LANGSMITH_PROJECT=secretaria
LANGSMITH_TRACING=false
