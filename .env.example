# ───────────────────────────────────────────
# Telegram
# ───────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_WEBHOOK_SECRET=your-webhook-secret
TELEGRAM_CHAT_ID=your-telegram-chat-id

# Comma-separated chat IDs allowed to use the bot (owner always allowed)
# Leave empty to allow only TELEGRAM_CHAT_ID
ALLOWED_CHAT_IDS=

# Public HTTPS base URL — used for Google OAuth redirect URI
APP_BASE_URL=https://sked-ai.duckdns.org

# ───────────────────────────────────────────
# ClickUp
# ───────────────────────────────────────────
CLICKUP_API_TOKEN=your-clickup-api-token
CLICKUP_TEAM_ID=your-clickup-team-id
CLICKUP_WEBHOOK_SECRET=your-clickup-webhook-secret

# ───────────────────────────────────────────
# Google AI Studio (Gemini Flash + Pro)
# Free tier: https://aistudio.google.com/apikey
# ───────────────────────────────────────────
GOOGLE_AI_API_KEY=AIza...

# ───────────────────────────────────────────
# App
# ───────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
APP_SECRET_KEY=your-app-secret-key

# ───────────────────────────────────────────
# Database
# ───────────────────────────────────────────
DATABASE_URL=sqlite:///./data/secretary.db

# ───────────────────────────────────────────
# Model routing
# simple/medium intents → gemini-flash (free tier, fast)
# complex intents       → gemini-pro   (free tier, stronger)
# ───────────────────────────────────────────
DEFAULT_MODEL=gemini-flash
COMPLEX_MODEL=gemini-pro

# ───────────────────────────────────────────
# LangSmith (optional — tracing)
# ───────────────────────────────────────────
LANGSMITH_API_KEY=ls__...
LANGSMITH_PROJECT=secretaria
LANGSMITH_TRACING=false
